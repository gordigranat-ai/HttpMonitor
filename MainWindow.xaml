<Window x:Class="HttpMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HTTP Monitor System" Height="850" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TabControl FontSize="13">
            <!-- Вкладка Сервер -->
            <TabItem Header="HTTP Сервер">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Панель управления -->
                        <Border Grid.Row="0" BorderBrush="#4CAF50" BorderThickness="2" CornerRadius="8" Padding="10" Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Порт:" VerticalAlignment="Center" FontSize="14" FontWeight="Bold"/>
                                <TextBox x:Name="PortBox" Text="8080" Width="80" FontSize="14" Margin="10,0"/>
                                <Button x:Name="StartBtn" Content="Запустить" Click="StartServer_Click" Background="#4CAF50" Foreground="White"/>
                                <Button x:Name="StopBtn" Content="Остановить" Click="StopServer_Click" Background="#F44336" Foreground="White" IsEnabled="False"/>
                                <TextBlock x:Name="StatusText" Text="Остановлен" Foreground="#F44336" Margin="20,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <!-- Статистика -->
                        <Border Grid.Row="1" BorderBrush="#2196F3" BorderThickness="2" CornerRadius="8" Padding="10" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#E3F2FD" CornerRadius="8" Padding="10" Margin="5">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="GET" FontSize="16" FontWeight="Bold" Foreground="#1565C0"/>
                                        <TextBlock x:Name="GetCountText" Text="0" FontSize="28" FontWeight="Bold" TextAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="#E8F5E9" CornerRadius="8" Padding="10" Margin="5">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="POST" FontSize="16" FontWeight="Bold" Foreground="#2E7D32"/>
                                        <TextBlock x:Name="PostCountText" Text="0" FontSize="28" FontWeight="Bold" TextAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Background="#FFF3E0" CornerRadius="8" Padding="10" Margin="5">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="Ср. время" FontSize="16" FontWeight="Bold" Foreground="#E65100"/>
                                        <TextBlock x:Name="AvgTimeText" Text="0 ms" FontSize="28" FontWeight="Bold" TextAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="3" Background="#F3E5F5" CornerRadius="8" Padding="10" Margin="5">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="Время работы" FontSize="16" FontWeight="Bold" Foreground="#6A1B9A"/>
                                        <TextBlock x:Name="UptimeText" Text="00:00:00" FontSize="28" FontWeight="Bold" TextAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Фильтры -->
                        <Border Grid.Row="2" BorderBrush="#FF9800" BorderThickness="2" CornerRadius="8" Padding="10" Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock Text="Фильтр:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                                <ComboBox x:Name="MethodFilterBox" Width="100" SelectionChanged="Filter_Changed">
                                    <ComboBoxItem Content="Все" IsSelected="True"/>
                                    <ComboBoxItem Content="GET"/>
                                    <ComboBoxItem Content="POST"/>
                                </ComboBox>
                                <TextBlock Text="Код ответа:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                                <TextBox x:Name="StatusFilterBox" Width="60" TextChanged="Filter_Changed"/>
                                <Button x:Name="ClearFilterBtn" Content="Очистить" Click="ClearFilter_Click" Background="#9E9E9E" Foreground="White"/>
                                <Button x:Name="ExportLogsBtn" Content="Экспорт" Click="ExportLogs_Click" Background="#4CAF50" Foreground="White"/>
                            </StackPanel>
                        </Border>

                        <!-- Логи -->
                        <Border Grid.Row="3" BorderBrush="#607D8B" BorderThickness="2" CornerRadius="8" Padding="10" Margin="0,0,0,15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Логи запросов" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                                <ListBox x:Name="LogsListBox" Grid.Row="1" Height="200" FontFamily="Consolas" FontSize="11"/>
                            </Grid>
                        </Border>

                        <!-- График нагрузки -->
                        <Border Grid.Row="4" BorderBrush="#9C27B0" BorderThickness="2" CornerRadius="8" Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="График пиковой нагрузки (запросов в минуту)" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                                <ListBox x:Name="LoadGraphListBox" Grid.Row="1" Height="130" FontFamily="Consolas" FontSize="12"/>
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- Вкладка Клиент -->
            <TabItem Header="HTTP Клиент">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" BorderBrush="#4CAF50" BorderThickness="2" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="URL запроса" FontWeight="Bold" FontSize="14"/>
                                <TextBox x:Name="UrlBox" Text="http://localhost:8080/" Margin="0,5,0,10" FontSize="13"/>

                                <TextBlock Text="Метод" FontWeight="Bold" FontSize="14"/>
                                <ComboBox x:Name="MethodBox" Width="120" Margin="0,5" SelectionChanged="MethodBox_SelectionChanged">
                                    <ComboBoxItem Content="GET" IsSelected="True"/>
                                    <ComboBoxItem Content="POST"/>
                                </ComboBox>

                                <TextBlock x:Name="BodyLabel" Text="Тело запроса (JSON)" FontWeight="Bold" FontSize="14" Margin="0,10,0,0" Visibility="Collapsed"/>
                                <TextBox x:Name="BodyBox" Height="100" TextWrapping="Wrap" AcceptsReturn="True" 
                                         Visibility="Collapsed" Margin="0,5,0,10" FontFamily="Consolas"
                                         Text="{}{&quot;message&quot;: &quot;Тестовое сообщение&quot;}"/>

                                <Button x:Name="SendBtn" Content="Отправить запрос" Click="SendRequest_Click" 
                                        Height="40" Background="#2196F3" Foreground="White" FontSize="14"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" BorderBrush="#FF9800" BorderThickness="2" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Ответ сервера" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                                <TextBox x:Name="ResponseBox" Grid.Row="1" Height="180" TextWrapping="Wrap" 
                                         IsReadOnly="True" Background="#F5F5F5" FontFamily="Consolas" FontSize="12"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" BorderBrush="#9C27B0" BorderThickness="2" CornerRadius="8" Padding="15">
                            <StackPanel>
                                <TextBlock Text="Примеры для тестирования" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                                <WrapPanel>
                                    <Button Content="GET: Посты JSONPlaceholder" Click="Example_Click" Tag="https://jsonplaceholder.typicode.com/posts" Background="#607D8B" Foreground="White"/>
                                    <Button Content="GET: Один пост" Click="Example_Click" Tag="https://jsonplaceholder.typicode.com/posts/1" Background="#607D8B" Foreground="White"/>
                                    <Button Content="GET: Cat Facts" Click="Example_Click" Tag="https://catfact.ninja/fact" Background="#607D8B" Foreground="White"/>
                                    <Button Content="POST: Отправить на свой сервер" Click="Example_Click" Tag="self" Background="#4CAF50" Foreground="White"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>